# Backend runtime
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Database
DATABASE_URL=jdbc:postgresql://postgres:5432/crm_db
DATABASE_USERNAME=crm_user
DATABASE_PASSWORD=crm_pass

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Mail
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=crm@example.com
MAIL_PASSWORD=change-me
PASSWORD_RESET_FROM_ADDRESS=no-reply@example.com
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_DEBUG=false

# JWT
JWT_SECRET=change-this-secret
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
LOGIN_LOCKOUT_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
PASSWORD_RESET_EXPIRATION_MINUTES=30
APP_FRONTEND_BASE_URL=http://localhost:5173
APP_PUBLIC_API_DOCS_ENABLED=false
APP_PUBLIC_ACTUATOR_ENABLED=false
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_COM_CRM=INFO
LOG_LEVEL_SPRING_SECURITY=INFO

# AI / OpenAI compatibility settings
OPENAI_API_KEY=

# Tenancy credential encryption key
# Supports plain values plus env:, file:, and base64: references.
TENANCY_DATABASE_CREDENTIALS_KEY=env:JWT_SECRET

# Governance automation
GOVERNANCE_AUTOMATION_ENABLED=true
GOVERNANCE_AUTOMATION_INTERVAL_MS=3600000
GOVERNANCE_AUTOMATION_INITIAL_DELAY_MS=300000

# Web push notifications (VAPID)
WEB_PUSH_ENABLED=true
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:notifications@example.com

# Document object storage
# Local Docker uses MinIO through the S3-compatible API.
FILE_STORAGE_TYPE=minio
MINIO_ROOT_USER=crm_minio
MINIO_ROOT_PASSWORD=change-this-minio-password
MINIO_API_PORT=9010
MINIO_CONSOLE_PORT=9011
S3_ENDPOINT=http://minio:9000
S3_BUCKET=crm-documents
S3_REGION=us-east-1
S3_ACCESS_KEY=crm_minio
S3_SECRET_KEY=change-this-minio-password
S3_PATH_STYLE_ACCESS=true
S3_CREATE_BUCKET=true

# Optional local filesystem fallback for debugging only.
FILE_UPLOAD_DIR=./uploads
