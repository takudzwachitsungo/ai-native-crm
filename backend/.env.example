# Backend runtime
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Database
DATABASE_URL=jdbc:postgresql://postgres:5432/crm_db
DATABASE_USERNAME=crm_user
DATABASE_PASSWORD=crm_pass

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Mail
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=crm@example.com
MAIL_PASSWORD=change-me
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_DEBUG=false

# JWT
JWT_SECRET=change-this-secret

# AI / OpenAI compatibility settings
OPENAI_API_KEY=

# Tenancy credential encryption key
# Supports:
# - plain value
# - env:MY_SECRET_ENV_VAR
# - file:/run/secrets/tenant_key
# - base64:...
TENANCY_DATABASE_CREDENTIALS_KEY=env:JWT_SECRET

# Governance automation
GOVERNANCE_AUTOMATION_ENABLED=true
GOVERNANCE_AUTOMATION_INTERVAL_MS=3600000
GOVERNANCE_AUTOMATION_INITIAL_DELAY_MS=300000
